# ============================================================
# STUDYHUB BACKEND - ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- Server ---
PORT=5000
NODE_ENV=development

# --- MongoDB ---
# Local:  mongodb://localhost:27017/studyhub
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/studyhub
MONGODB_URI=mongodb://localhost:27017/studyhub

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_KEY_64_CHARS_MIN
JWT_EXPIRE=7d

# --- Email (NodeMailer) ---
# ⚠️ INSERT YOUR EMAIL CREDENTIALS HERE ⚠️
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_TO=mbd2921996@gmail.com

# --- Stripe Payment Gateway ---
# ⚠️ INSERT YOUR STRIPE KEYS HERE ⚠️
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET

# --- Razorpay (Alternative Payment) ---
# ⚠️ INSERT YOUR RAZORPAY KEYS HERE ⚠️
# Get keys from: https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=rzp_test_REPLACE_WITH_KEY_ID
RAZORPAY_KEY_SECRET=REPLACE_WITH_KEY_SECRET

# --- File Storage ---
# 'local' for development, 'cloud' for production (AWS S3, Cloudinary, etc.)
STORAGE_TYPE=local
UPLOADS_DIR=uploads

# --- Frontend URL (for CORS) ---
FRONTEND_URL=http://localhost:3000

# --- Admin Seed ---
ADMIN_EMAIL=admin@studyhub.com
ADMIN_PASSWORD=Admin@123456
